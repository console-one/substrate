    {
      "id": "github_projects",
      "displayName": "GitHub Projects",
      "usedBy": [
        "github_projects.list_org_projects",
        "github_projects.get_project",
        "github_projects.list_project_fields",
        "github_projects.list_project_items"
      ],
      "install": {
        "fields": [
          {
            "id": "github_projects.token",
            "label": "GitHub Personal Access Token",
            "description": "Token for GitHub Projects v2 (GraphQL). Needs read:org for org projects and/or read:user for user projects.",
            "type": "secret",
            "required": true,
            "constantKey": "github_projects.token",
            "placeholder": "ghp_..."
          },
          {
            "id": "github_projects.owner",
            "label": "Default Owner (org or user login)",
            "description": "Used as the default scope for listing projects.",
            "type": "string",
            "required": true,
            "constantKey": "github_projects.owner",
            "placeholder": "owner organization name"
          }
        ]
      },
      "bindings": [
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.github_projects.authHeader",
          "values": { "expr": "concat('Bearer ', const.github_projects.token)" }
        },
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.github_projects.owner",
          "values": { "expr": "const.github_projects.owner" }
        }
      ]
    },
