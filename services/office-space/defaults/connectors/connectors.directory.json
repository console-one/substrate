      ],

      "install": {
        "fields": [
          {
            "id": "fireflies.apiKey",
            "label": "Fireflies API Key",
            "description": "Used for Authorization: Bearer <key>.",
            "type": "secret",
            "required": true,
            "constantKey": "fireflies.apiKey",
            "placeholder": "api_key_here"
          }
        ]
      },

      "bindings": [
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.fireflies.authHeader",
          "values": {
            "expr": "concat('Bearer ', const.fireflies.apiKey)"
          }
        }
      ]
    },

    {
      "id": "drive",
      "displayName": "Google Drive",
      "usedBy": [
        "drive.list_files",
        "drive.list_folder",
        "drive.get_file",
        "drive.download_file",
