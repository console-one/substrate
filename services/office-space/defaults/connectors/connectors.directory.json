            "type": "oauth",
            "required": true,
            "constantKey": "xero.tokenRef"
          }
        ]
      },
      "bindings": [
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.xero.authHeader",
          "values": {
            "expr": "concat('Bearer ', oauth(const.xero.tokenRef))"
          }
        },
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.xero.accountingBase",
          "values": {
            "expr": "'https://api.xero.com/api.xro/2.0'"
          }
        }
      ]
    },
