            "constantKey": "bitbucket.workspace",
            "placeholder": "workspace-name"
          },
          {
            "id": "bitbucket.repo",
            "label": "Default Repository",
            "description": "Repo slug (e.g. lens-desktop).",
            "type": "string",
            "required": false,
            "constantKey": "bitbucket.repo",
            "placeholder": "repo-name"
          }
        ]
      },

      "bindings": [
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.bitbucket.authHeader",
          "values": {
            "expr": "concat('Bearer ', const.bitbucket.token)"
          }
        },
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.bitbucket.defaultWorkspace",
          "values": {
            "expr": "const.bitbucket.workspace"
          }
        },
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.bitbucket.defaultRepo",
          "values": {
            "expr": "const.bitbucket.repo"
          }
        }
      ]
    },

    {
