{
  "version": "2025-01-01",
  "connectors": [
    {
      "id": "github",
      "displayName": "GitHub",
      "usedBy": [
        "github.fetch_commit_diffs",
        "github.fetch_commits_by_date",
        "github.fetch_pull_requests",
        "github.fetch_pull_request",
        "github.fetch_pull_request_files",
        "github.fetch_contributors",
        "github.fetch_branches",
        "github.fetch_file_contents"
      ],

      "install": {
        "fields": [
          {
            "id": "github.token",
            "label": "GitHub Personal Access Token",
            "description": "Token with repo read access.",
            "type": "secret",
            "required": true,
            "constantKey": "github.token",
            "placeholder": "ghp_..."
          },
          {
            "id": "github.owner",
            "label": "Default Owner (org or user)",
            "description": "e.g. console-one",
            "type": "string",
            "required": true,
            "constantKey": "github.owner",
            "placeholder": "owner-name"
          },
          {
            "id": "github.repo",
            "label": "Default Repository (optional)",
            "description": "e.g. lens-desktop. APIs can override.",
            "type": "string",
            "required": false,
            "constantKey": "github.repo",
            "placeholder": "repo-name"
          }
        ]
      },

      "bindings": [
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.github.authHeader",
          "values": {
            "expr": "concat('Bearer ', const.github.token)"
          }
        },
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.github.defaultOwner",
          "values": {
            "expr": "const.github.owner"
          }
        },
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.github.defaultRepo",
          "values": {
            "expr": "const.github.repo"
          }
        },
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.github.apiBase",
          "values": {
            "expr": "'https://api.github.com'"
          }
        }
      ]
    },

    {
      "id": "jira",
      "displayName": "Jira",
      "usedBy": [
        "jira.search_issues",
        "jira.get_issue",
        "jira.get_issue_changelog",
        "jira.list_projects",
        "jira.get_project",
        "jira.list_issue_comments",
        "jira.users_assignable",
        "jira.myself",
        "jira.agile_list_boards",
        "jira.agile_list_sprints",
        "jira.agile_sprint_issues"
      ],

      "install": {
        "fields": [
          {
            "id": "jira.baseUrl",
            "label": "Jira Base URL",
            "description": "e.g. your-org.atlassian.net (no https://).",
            "type": "string",
            "required": true,
            "constantKey": "jira.baseUrl",
            "placeholder": "your-org.atlassian.net"
          },
          {
            "id": "jira.email",
            "label": "Jira Account Email",
            "description": "Used for Basic auth with API token.",
            "type": "email",
            "required": true,
            "constantKey": "jira.email",
            "placeholder": "you@company.com"
          },
          {
            "id": "jira.apiToken",
            "label": "Jira API Token",
            "description": "Personal API token from Atlassian.",
            "type": "secret",
            "required": true,
            "constantKey": "jira.apiToken",
            "placeholder": "atlassian_api_token"
          }
        ]
      },

      "bindings": [
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.jira.basicAuth",
          "values": {
            "expr": "concat('Basic ', base64(concat(const.jira.email, ':', const.jira.apiToken)))"
          }
        },
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.jira.baseUrl",
          "values": {
            "expr": "concat('https://', const.jira.baseUrl)"
          }
        }
      ]
    },

    {
      "id": "fathom",
      "displayName": "Fathom",
      "usedBy": [
        "fathom.list_meetings",
        "fathom.get_recording_summary",
        "fathom.get_recording_transcript",
        "fathom.list_teams",
        "fathom.list_team_members"
      ],

      "install": {
        "fields": [
          {
            "id": "fathom.apiKey",
            "label": "Fathom API Key",
            "description": "Get from Fathom developer settings.",
            "type": "secret",
            "required": true,
            "constantKey": "fathom.apiKey",
            "placeholder": "api_key_here"
          }
        ]
      },

      "bindings": [
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.fathom.apiKey",
          "values": {
            "expr": "const.fathom.apiKey"
          }
        }
      ]
    },

    {
      "id": "fireflies",
      "displayName": "Fireflies",
      "usedBy": [
        "fireflies.fetch_transcripts",
