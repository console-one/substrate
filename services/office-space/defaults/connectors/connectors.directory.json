        "tldv.get_transcript",
        "tldv.get_highlights"
      ],
      "install": {
        "fields": [
          {
            "id": "tldv.apiKey",
            "label": "tl;dv API Key",
            "description": "API key generated in tl;dv personal settings.",
            "type": "secret",
            "required": true,
            "constantKey": "tldv.apiKey",
