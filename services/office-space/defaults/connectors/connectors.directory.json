            "description": "OAuth token reference for Google Drive access.",
            "type": "oauth",
            "required": true,
            "constantKey": "gdrive.tokenRef"
          }
        ]
      },

      "bindings": [
        {
          "schematictype": { "typename": "binding" },
          "id": "binding.gdrive.authHeader",
          "values": {
            "expr": "concat('Bearer ', oauth(const.gdrive.tokenRef))"
          }
        }
      ]
    },

