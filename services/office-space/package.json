{
  "name": "@ft/office-space",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "office-space": "bin/office-space.cjs"
  },
  "scripts": {
    "build": "tsc",
    "build:web": "node scripts/build-web.cjs",
    "build:web:watch": "node scripts/build-web.cjs --watch",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --forceExit --detectOpenHandles",
    "start": "tsx src/index.ts start",
    "console": "tsx src/index.ts console",
    "clean": "rm -rf dist dist-web"
  },
  "dependencies": {
    "@console-one/sequence": "^0.1.0",
    "@console-one/sequenceutils": "^0.1.0",
    "better-sqlite3": "^11.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/jest": "^29.5.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "jsdom": "^29.0.2",
    "ts-jest": "^29.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
